{
  "name": "logseq-datenlp-plugin",
  "author": "benjypng",
  "description": "Auto-insert dates using NLP.",
  "license": "MIT",
  "logseq": {
    "id": "logseq-datenlp-plugin",
    "title": "logseq-datenlp-plugin",
    "icon": "./icon.svg",
    "main": "dist/index.html"
  },
  "scripts": {
    "dev": "bunx vite",
    "build": "bunx vite build",
    "build:plugin": "bunx eslint . --fix && bunx tsc && bunx vite build",
    "prepare": "husky",
    "lint:precommit": "echo \"Running biome\" && bunx biome check . --write && echo \"Running tsc\" && tsc --noEmit"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/github",
        {
          "assets": [
            "logseq-datenlp-plugin.zip"
          ]
        }
      ]
    ]
  },
  "dependencies": {
    "@benjypng/ls-plugin-design-system": "^0.2.1",
    "@logseq/libs": "^0.2.8",
    "chrono-node": "^2.9.0",
    "date-fns": "^4.1.0",
    "logseq-dateutils": "^2.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-logseq": "^1.1.2",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
